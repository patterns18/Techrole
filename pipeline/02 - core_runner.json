										"type": "Expression"
									},
									"direction": "Input"
								},
								{
									"name": "Metrics",
									"type": "String",
									"value": {
										"value": "@concat(\n    '{\"filename\": \"',pipeline().parameters.AssetItem.file_name,pipeline().parameters.AssetItem.file_type, \n    '\", ',\n    '\"target_folder_path\": \"',pipeline().parameters.AssetItem.sink_container,'/',pipeline().parameters.AssetItem.sink_path,pipeline().parameters.TargetFolderSuffix,'/',pipeline().parameters.AssetItem.file_name,'/',pipeline().parameters.AssetItem.file_name,'\"/}')",
										"type": "Expression"
									},
									"direction": "Input"
								},
								{
									"name": "ErrorMessage",
									"type": "String",
									"value": {
										"value": "@variables('ErrMessage')",
										"type": "Expression"
									},
									"direction": "Input"
								}
							],
							"type": "Query",
							"text": "\nEXEC olaniyi_metadata.usp_end_activity_run\n    @ActivityId = @ActivityId,\n    @Status=    @Status,\n    @Metrics = @Metrics,\n    @ErrorMessage = @ErrorMessage;"
						}
					],
					"scriptBlockExecutionTimeout": "02:00:00"
				}
			},
			{
				"name": "Set variable1",
				"type": "SetVariable",
				"dependsOn": [
					{
						"activity": "Switch_Route_By_Type",
						"dependencyConditions": [
							"Failed"
						]
					}
				],
				"policy": {
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"variableName": "ErrMessage",
					"value": {
						"value": "@if(\n    equals(\n        concat(\n            activity('Switch_Route_By_Type').Error.Message, variables('ErrMessage_adls_adls'),\n                variables('ErrMessage_adls_sql')\n                ), \n\n    null), '', concat(\n            activity('Switch_Route_By_Type').Error.Message,'.' ,variables('ErrMessage_adls_adls'),'.',\n                variables('ErrMessage_adls_sql')\n                )\n    )",
						"type": "Expression"
					}
				}
