					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"linkedServiceName": {
					"referenceName": "ls_sql_dataroleacademy",
					"type": "LinkedServiceReference"
				},
				"typeProperties": {
					"scripts": [
						{
							"parameters": [
								{
									"name": "BatchId",
									"type": "Int64",
									"value": {
										"value": "@pipeline().parameters.ParentRunId",
										"type": "Expression"
									},
									"direction": "Input"
								},
								{
									"name": "AssetName",
									"type": "String",
									"value": {
										"value": "@pipeline().parameters.AssetItem.asset_name",
										"type": "Expression"
									},
									"direction": "Input"
								},
								{
									"name": "ActivityName",
									"type": "String",
									"value": {
										"value": "@pipeline().parameters.AssetItem.type_name",
										"type": "Expression"
									},
									"direction": "Input"
								},
								{
									"name": "ActivityType",
									"type": "String",
									"value": "'core_runner'",
									"direction": "Input"
								}
							],
							"type": "Query",
							"text": "DECLARE @ActivityId  BIGINT;\nEXEC olaniyi_metadata.usp_start_activity_run\n    @BatchId =     @BatchId,\n    @AssetName = @AssetName,\n    @ActivityName = @ActivityName,\n    @ActivityType =     @ActivityType,\n    @ActivityId = @ActivityId  OUTPUT;\n\nSELECT  @ActivityId  AS ActivityId "
						}
					],
					"scriptBlockExecutionTimeout": "02:00:00"
				}
			},
			{
				"name": "end_activity_log",
				"type": "Script",
				"dependsOn": [
					{
						"activity": "Switch_Route_By_Type",
						"dependencyConditions": [
							"Completed"
						]
					}
				],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"linkedServiceName": {
					"referenceName": "ls_sql_dataroleacademy",
					"type": "LinkedServiceReference"
				},
				"typeProperties": {
					"scripts": [
						{
							"parameters": [
								{
									"name": "ActivityId",
									"type": "Int64",
									"value": {
										"value": "@activity('start_activity_log').output.resultSets[0].rows[0].ActivityId",
										"type": "Expression"
									},
									"direction": "Input"
								},
								{
									"name": "Status",
									"type": "String",
									"value": {
